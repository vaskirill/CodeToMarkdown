# Code to Markdown Configuration
# Copy this file to .env and adjust the values as needed

# Application Settings
APP_NAME=Code to Markdown
APP_VERSION=1.2.0
DEBUG=false
LOG_LEVEL=INFO

# File Processing Settings
MAX_FILE_SIZE_MB=5
INCLUDE_GITIGNORE=true
INCLUDE_CONFIG_FILES=true
INCLUDE_LARGE_FILES=false

# UI Settings
THEME=light
LANGUAGE=ru
WINDOW_WIDTH=1200
WINDOW_HEIGHT=800

# Markdown Generation Settings
INCLUDE_TOC=true
INCLUDE_APPENDICES=true
INCLUDE_FILE_STATS=true
INCLUDE_ANNOTATIONS=true

# Logging Settings
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# Development Settings
DEV_MODE=false
ENABLE_PROFILING=false
MOCK_FILE_SYSTEM=false

# Security Settings
ALLOWED_EXTENSIONS=.py,.js,.ts,.html,.css,.md,.json,.yaml,.yml,.toml,.ini,.cfg,.conf,.txt,.sh,.bat,.cmd
BLOCKED_EXTENSIONS=.exe,.dll,.so,.dylib,.bin,.dat,.db,.sqlite,.log

# Performance Settings
MAX_CONCURRENT_FILES=10
CHUNK_SIZE=8192
MEMORY_LIMIT_MB=512

# Export Settings
DEFAULT_OUTPUT_FORMAT=markdown
INCLUDE_METADATA=true
COMPRESS_OUTPUT=false
